{
  "manifest_version": 3,
  "name": "Extensão EscolaRS",
  "version": "0.4.2",
  "icons": {
    "16": "images/icons/icon16.png",
    "48": "images/icons/icon48.png",
    "128": "images/icons/icon128.png"
  },
  "description": "Auxilia o professor na gestão de notas.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.procergs.com.br/*",
    "https://professor.escola.rs.gov.br/*"
  ],
  "action": {
    "default_title": "Abrir Dashboard de Notas"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ui/dashboard/dashboard.html",
        "ui/chamada/chamada.html",
        "ui/avaliacoes/avaliacoes.html",
        "libs/xlsx.full.min.js",
        "tests/gerar_dados_xls.html",
        "tests/gerar_dados_xls.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
{
  "manifest_version": 3,
  "name": "EscolaRS Export",
  "version": "0.2.4",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "description": "Exporta notas do EscolaRS para Excel.",
  "permissions": ["storage", "tabs", "notifications"],
  "host_permissions": [
    "https://*.procergs.com.br/*",
    "https://professor.escola.rs.gov.br/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://professor.escola.rs.gov.br/*"],
      "js": ["autenticacao.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Abrir Dashboard de Notas"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
{
  "manifest_version": 3,
  "name": "EscolaRS Export",
  "version": "0.3.4",
  "icons": {
    "16": "images/icons/icon16.png",
    "48": "images/icons/icon48.png",
    "128": "images/icons/icon128.png"
  },
  "description": "Exporta notas do EscolaRS para Excel.",
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.procergs.com.br/*",
    "https://professor.escola.rs.gov.br/*"
  ],
  "action": {
    "default_title": "Abrir Dashboard de Notas"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ui/dashboard/dashboard.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}